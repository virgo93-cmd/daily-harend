			<h2>Disclaimer</h2>
			<p>To the maximum extent permitted by applicable law, we exclude all representations, warranties and conditions relating to our website and the use of this website.</p>
		</article>
	</main>
</MainLayout>

<style>
	.legal-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.legal-content {
		background-color: #ffffff;
		padding: 2.5rem;
		border-radius: 12px;
		border: 1px solid #e5e7eb;
		line-height: 1.7;
		color: #374151;
	}

	.legal-content h1 {
		margin: 0 0 0.5rem 0;
		font-size: 2.25rem;
		font-weight: 800;
		color: #111827;
		letter-spacing: -0.025em;
	}

	.last-updated {
		color: #6b7280;
		font-size: 0.875rem;
		margin-bottom: 2rem;
	}

	.legal-content h2 {
		margin: 2rem 0 1rem 0;
		font-size: 1.5rem;
		font-weight: 700;
		color: #111827;
		letter-spacing: -0.025em;
	}

	.legal-content p {
		margin: 0 0 1.25rem 0;
	}

	.legal-content ul {
		margin: 0 0 1.5rem 0;
		padding-left: 1.5rem;
	}

	.legal-content li {
		margin-bottom: 0.5rem;
	}

	/* Responsif untuk HP */
	@media (max-width: 640px) {
		.legal-content {
			padding: 1.5rem;
		}
		.legal-content h1 {
			font-size: 1.75rem;
		}
		.legal-content h2 {
			font-size: 1.25rem;
		}
	}
</style>