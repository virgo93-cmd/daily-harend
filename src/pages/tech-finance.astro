---
import MainLayout from '../layouts/MainLayout.astro';
import TrendingCard from '../components/TrendingCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// Ambil semua artikel dari koleksi 'blog' yang berada di dalam folder 'tech-finance'
const techFinanceArticles = await getCollection('blog', ({ id }: CollectionEntry<'blog'>) => {
	return id.startsWith('tech-finance/');
});

// Urutkan berdasarkan tanggal terbaru
techFinanceArticles.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout>
	<main class="category-container">
		<header class="category-header">
			<span class="category-label">Category</span>
			<h1>Tech & Finance</h1>
			<p>Insights into emerging technologies, market trends, financial hacks, and global economic updates.</p>
		</header>

		<section class="articles-grid">
			{techFinanceArticles.map((article: CollectionEntry<'blog'>) => (
				<TrendingCard 
					title={article.data.title}
					description={article.data.description}
					pubDate={article.data.pubDate}
					category={article.data.category}
					readingTime={article.data.readingTime}
					url={`/blog/${article.id}`}
					/* FIX: GAMBAR SEKARANG DIOPER BIAR MUNCUL DI HALAMAN KATEGORI TECH & FINANCE */
					image={article.data.image}
				/>
			))}
		</section>
	</main>
</MainLayout>

<style>
	.category-container {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.category-header {
		border-bottom: 2px solid #e5e7eb;
		padding-bottom: 2rem;
	}

	.category-label {
		display: inline-block;
		color: #2563eb;
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.category-header h1 {
		margin: 0 0 0.75rem 0;
		font-size: 2.25rem;
		font-weight: 800;
		color: #111827;
		letter-spacing: -0.025em;
	}

	.category-header p {
		margin: 0;
		color: #4b5563;
		font-size: 1.1rem;
		line-height: 1.5;
		max-width: 800px;
	}

	/* GRID RESPONSIF UNTUK HALAMAN KATEGORI */
	.articles-grid {
		display: grid;
		grid-template-columns: 1fr; /* HP: 1 Kolom */
		gap: 1.5rem;
	}

	/* Breakpoint untuk Tablet */
	@media (min-width: 640px) {
		.articles-grid {
			grid-template-columns: repeat(2, 1fr); /* Tablet: 2 Kolom Sejajar */
		}
	}

	/* Breakpoint untuk Laptop & Desktop */
	@media (min-width: 1024px) {
		.articles-grid {
			grid-template-columns: repeat(3, 1fr); /* Layar Lebar: 3 Kolom Sejajar */
		}
	}
</style>