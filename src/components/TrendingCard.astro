---
// src/components/TrendingCard.astro
const { title, description, pubDate, category, readingTime, url, image } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});
---
<article class="trending-card">
	{image && (
		<div class="card-image-wrapper">
			<a href={url} class="card-image-link">
				<img src={image} alt={title} class="card-img" loading="lazy" />
			</a>
		</div>
	)}

	<div class="card-content">
		<span class="category-tag">{category}</span>
		<h3 class="card-title">
			<a href={url}>{title}</a>
		</h3>
		<p class="card-desc">{description}</p>
		<div class="card-meta">
			<span>{formattedDate}</span>
			<span class="meta-dot">&bull;</span>
			<span>{readingTime}</span>
		</div>
	</div>
</article>

<style>
	.trending-card {
		background-color: #ffffff;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%; /* Kunci lebar agar patuh pada grid induk */
		box-sizing: border-box;
	}

	.trending-card:hover {
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
	}

	/* Wrapper Gambar Utama - DIKUNCI MATI BIAR GAK JEBOL */
	.card-image-wrapper {
		width: 100%;
		max-width: 100%;
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background-color: #f1f5f9;
		border-bottom: 1px solid #e5e7eb;
	}

	.card-image-link {
		display: block;
		width: 100%;
		height: 100%;
	}

	.card-img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover; /* Memotong gambar secara proporsional di dalam kotak */
		transition: transform 0.3s ease;
	}

	.trending-card:hover .card-img {
		transform: scale(1.04);
	}

	.card-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.category-tag {
		color: #2563eb;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.card-title {
		margin: 0 0 0.5rem 0;
		font-size: 1.15rem;
		line-height: 1.4;
		font-weight: 700;
		/* MEMBATASI JUDUL MAKSIMAL 2 BARIS BIAR RAPI */
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-title a {
		color: #111827;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.card-title a:hover {
		color: #2563eb;
	}

	.card-desc {
		margin: 0 0 1rem 0;
		color: #4b5563;
		font-size: 0.9rem;
		line-height: 1.5;
		flex-grow: 1;
		/* MEMBATASI DESKRIPSI MAKSIMAL 3 BARIS BIAR TINGGI KARTU SEJAJAR */
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #6b7280;
		font-size: 0.815rem;
		margin-top: auto;
	}

	.meta-dot {
		color: #d1d5db;
	}
</style>